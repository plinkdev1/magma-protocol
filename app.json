{
    "expo":  {
                 "name":  "MAGMA",
                 "slug":  "magma",
                 "scheme":  "magma",
                 "version":  "1.0.0",
                 "orientation":  "portrait",
                 "icon":  "./assets/images/icon.png",
                 "userInterfaceStyle":  "dark",
                 "backgroundColor":  "#080400",
                 "owner":  "plinkdev",
                 "splash":  {
                                "image":  "./assets/images/splash.png",
                                "resizeMode":  "cover",
                                "backgroundColor":  "#080400"
                            },
                 "assetBundlePatterns":  [
                                             "**/*"
                                         ],
                 "ios":  {
                             "supportsTablet":  false,
                             "bundleIdentifier":  "com.magmaprotocol.app",
                             "infoPlist":  {
                                               "NSSpeechRecognitionUsageDescription":  "Allow $(PRODUCT_NAME) to use speech recognition.",
                                               "NSMicrophoneUsageDescription":  "Allow $(PRODUCT_NAME) to use the microphone."
                                           }
                         },
                 "android":  {
                                 "adaptiveIcon":  {
                                                      "foregroundImage":  "./assets/images/adaptive-icon.png",
                                                      "backgroundColor":  "#080400"
                                                  },
                                 "package":  "com.magmaprotocol.app",
                                 "permissions":  [
                                                     "RECORD_AUDIO",
                                                     "CAMERA",
                                                     "VIBRATE",
                                                     "RECEIVE_BOOT_COMPLETED",
                                                     "POST_NOTIFICATIONS",
                                                     "FOREGROUND_SERVICE",
                                                     "WAKE_LOCK",
                                                     "android.permission.RECORD_AUDIO",
                                                     "android.permission.USE_BIOMETRIC",
                                                     "android.permission.USE_FINGERPRINT"
                                                 ],
                                 "allowBackup":  false,
                                 "softwareKeyboardLayoutMode":  "pan"
                             },
                 "plugins":  [

                             ],
                 "extra":  {
                               "eas":  {
                                           "projectId":  "0050889b-d34a-4390-a27a-20126432013d"
                                       }
                           }
             }
}
